# Node modules
node_modules/

# Lockfile is intentionally not tracked — `~/.npmrc` has
# `package-lock=false` so a committed lockfile would drift from
# package.json on every dep change and break `npm ci` in CI.
# CI's install step falls back to `npm install` when the lockfile
# is absent, which is what we want.
package-lock.json

# TypeScript build output
dist/
dist-test/
dist-e2e/

# Compiled frontend output: each .ts under public/js/ produces a
# sibling .js. The whole frontend is TS now (see PRs #73–#76);
# every emitted JS in this directory is a build artifact.
public/js/*.js

# Playwright outputs
playwright-report/
test-results/

# IDE files
.vscode/

# CodeRabbit local review output (cr review --plain piped to a file)
cr-review*

# testbuilds
*.tgz

# samples
samples/

# Generated test fixtures — rebuilt by pretest via test/fixtures/create-test-*.cjs
test/fixtures/test-chart.mbtiles
test/fixtures/test-vector-chart.mbtiles
