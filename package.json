{
  "name": "signalk-charts-provider-simple",
  "version": "2.1.0",
  "description": "Simple Signal K chart provider for local MBTiles with web and download management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "assets",
    "public",
    "docs/screenshots"
  ],
  "scripts": {
    "build": "tsc && npm run build:public",
    "build:watch": "tsc --watch",
    "build:tests": "tsc -p tsconfig.test.json",
    "build:e2e": "tsc -p tsconfig.e2e.json",
    "build:public": "tsc -p tsconfig.public.json",
    "pretest": "npm run build && npm run build:tests && npm run test:fixtures",
    "test": "node --test --test-force-exit dist-test/**/*.test.js",
    "test:fixtures": "node test/fixtures/create-test-mbtiles.cjs",
    "test:e2e": "npm run build && npm run build:e2e && playwright test",
    "lint": "eslint src test e2e public/js playwright.config.ts",
    "lint:fix": "eslint src test e2e public/js playwright.config.ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' 'e2e/**/*.ts' 'public/js/**/*.ts' 'playwright.config.ts' && eslint src test e2e public/js playwright.config.ts --fix",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' 'e2e/**/*.ts' 'public/js/**/*.ts' 'playwright.config.ts' && eslint src test e2e public/js playwright.config.ts",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-chart-plotters",
    "signalk-category-utility"
  ],
  "author": {
    "name": "Dirk Wahrheit"
  },
  "dependencies": {
    "@signalk/server-api": "^2.0.0",
    "@sinclair/typebox": "^0.34.49",
    "busboy": "^1.6.0",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirkwa/signalk-charts-provider-simple"
  },
  "bugs": {
    "url": "https://github.com/dirkwa/signalk-charts-provider-simple/issues"
  },
  "signalk-plugin-enabled-by-default": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "signalk": {
    "appIcon": "assets/charts_logo.png",
    "displayName": "Charts Provider Simple",
    "recommends": [
      "signalk-container"
    ],
    "screenshots": [
      "./docs/screenshots/1_charts-provider-simple.png",
      "./docs/screenshots/2_charts-provider-simple.png",
      "./docs/screenshots/3_charts-provider-simple.png",
      "./docs/screenshots/4_charts-provider-simple.png",
      "./docs/screenshots/5_charts-provider-simple.png",
      "./docs/screenshots/6_charts-provider-simple.png"
    ],
    "appstore": {
      "displayName": "Charts Provider Simple",
      "categories": [
        "utilities"
      ],
      "author": "Dirk Wahrheit",
      "description": "Simple Signal K chart provider for local MBTiles with web and download management"
    },
    "webapp": {
      "name": "Charts Provider Simple",
      "description": "Simple Signal K chart provider for local MBTiles with web and download management",
      "location": "/plugins/signalk-charts-provider-simple/"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.59.1",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.0",
    "@types/unzipper": "^0.10.11",
    "@types/xml2js": "^0.4.14",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "express": "^5.2.1",
    "prettier": "^3.7.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
